# tasker — environment contract
# Copy to `.env` and fill in secrets. Real .env is gitignored.

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_SETTINGS_MODULE=tasker.settings.dev
DEBUG=1
ALLOWED_HOSTS=*

# Postgres (used by both `web` and `db` services; `db` uses the same
# POSTGRES_* vars to provision the database on first boot).
POSTGRES_DB=tasker
POSTGRES_USER=tasker
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis (cache + Channels layer)
REDIS_URL=redis://redis:6379/0

# nginx host port. Override for parallel stacks (e.g. HTTP_PORT=8080).
HTTP_PORT=80

# Container app user UID. Set to $(id -u) on Linux to avoid bind-mount
# UID mismatch (host user can't delete __pycache__ written by the container).
# Default 1000 matches the typical first non-root Linux user.
UID=1000

# Dev superuser auto-bootstrap (IDEA-002). The web container's entrypoint
# provisions this user on first start when DJANGO_SETTINGS_MODULE points at
# the dev settings module. Leave USERNAME or PASSWORD blank to skip
# auto-creation. The branch is hard-guarded on `tasker.settings.dev` so a
# misconfigured prod deploy cannot accidentally create an admin from env.
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=admin
